<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Size Guide</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="sizechart.css">
</head>

<body>

    <section class="size-guide">
        <h1>Size Chart</h1>
        <h2>How to Measure Yourself (Men)</h2>
        <div class="breadcrumb">
            <a href="/">Home</a> › Terms & Conditions
        </div>


        <p class="info-text">
            Please use the chart below to decide which size to order.
        </p>
        <p class="info-text">
            If you would like more specific information about sizing of a particular garment,
            please contact customer care with your question.
        </p>

        <div class="container">

            <!-- Left Side -->
            <div class="measure-text">
                <h3>CHEST</h3>
                <p>Measure around the fullest part of your chest.</p>

                <h3>WAIST</h3>
                <p>Measure around your natural waistline.</p>

                <h3>SHOULDER</h3>
                <p>Measure from one shoulder edge to the other.</p>

                <h3>INSEAM</h3>
                <p>Measure from crotch to bottom of ankle.</p>
            </div>

            <!-- Right Side Table -->
            <div class="size-table">
                <table>
                    <tr>
                        <th>Size</th>
                        <th>Chest (in)</th>
                        <th>Waist (in)</th>
                        <th>Shoulder (in)</th>
                    </tr>
                    <tr>
                        <td>S</td>
                        <td>36-38</td>
                        <td>30-32</td>
                        <td>16-17</td>
                    </tr>
                    <tr>
                        <td>M</td>
                        <td>38-40</td>
                        <td>32-34</td>
                        <td>17-18</td>
                    </tr>
                    <tr>
                        <td>L</td>
                        <td>40-42</td>
                        <td>34-36</td>
                        <td>18-19</td>
                    </tr>
                    <tr>
                        <td>XL</td>
                        <td>42-44</td>
                        <td>36-38</td>
                        <td>19-20</td>
                    </tr>
                    <tr>
                        <td>XXL</td>
                        <td>44-46</td>
                        <td>38-40</td>
                        <td>20-21</td>
                    </tr>
                </table>
            </div>

        </div>
    </section>

</body>

</html>