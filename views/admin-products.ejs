<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FIT-FLICK | Products</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/shared.css" />
    <script src="/shared.js"></script>
</head>

<body>

    <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h2><a href="/">FIT-FLICK</a></h2>
            <button class="close-btn" onclick="closeSidebar()"><i class="fa fa-times"></i></button>
        </div>
        <ul>
            <li>
                <a href="/admin"><i class="fa fa-home"></i> Dashboard</a>
            </li>
            <li>
                <a href="/admin/products"><i class="fa fa-tshirt"></i> Products</a>
            </li>
            <li>
                <a href="/admin/orders"><i class="fa fa-box"></i> Orders</a>
            </li>
            <li>
                <a href="/admin/customers"><i class="fa fa-users"></i> Customers</a>
            </li>
        </ul>
    </div>

    <div class="main">
        <div class="topbar">
            <div class="topbar-left">
                <button class="hamburger" onclick="openSidebar()"><i class="fa fa-bars"></i></button>
                <input type="text" placeholder="Search products..." id="searchInput" oninput="filterTable()" />
            </div>
            <a href="/profile" class="profile-link">
                <div class="profile-icon"><i class="fa fa-user"></i></div>
                <span class="profile-name">Admin</span>
            </a>
        </div>

        <div class="page-title">
            <h1>Products</h1>
            <p>Manage your clothing inventory</p>
        </div>

        <!-- Filters & Add -->
        <div class="filters-bar">
            <div class="filter-group">
                <select id="catFilter" onchange="filterTable()">
                    <option value="">All Categories</option>
                    <option>Hoodie</option>
                    <option>T-Shirt</option>
                    <option>Jacket</option>
                    <option>Bottoms</option>
                    <option>Cap</option>
                    <option>Dress</option>
                </select>
                <select id="statusFilter" onchange="filterTable()">
                    <option value="">All Status</option>
                    <option>Active</option>
                    <option>Low</option>
                    <option>Inactive</option>
                </select>
            </div>
            <button class="save-btn" onclick="toggleModal(true)" style="margin-top:0;padding:10px 20px;font-size:13px;">
                <i class="fa fa-plus"></i> Add Product
            </button>
        </div>

        <div class="table-container">
            <table id="productTable">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <% products.forEach(p=> {
                        %>
                        <tr data-cat="<%= p.category?.title %>">
                            <td>
                                <img src="<%= p.images?.[0]?.picURL || 'https://via.placeholder.com/55' %>"
                                    class="product-img" alt="<%= p.name %>" />
                            </td>
                            <td>
                                <%= p.name %>
                            </td>
                            <td>
                                <%= p.category?.title || 'N/A' %>
                            </td>
                            <td>₹<%= p.price.toLocaleString('en-IN') %>
                            </td>
                            <td>
                                <button class="action-btn edit" onclick="editProduct('<%= p._id %>')">Edit</button>
                                <button class="action-btn delete"
                                    onclick="deleteProduct('<%= p._id %>', this)">Delete</button>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Product Modal -->
    <div class="modal-overlay" id="modalOverlay" onclick="toggleModal(false)"></div>
    <div class="modal" id="modal">
        <div class="modal-header">
            <h3>Add New Product</h3>
            <button onclick="toggleModal(false)"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-grid" style="grid-template-columns:1fr 1fr;">
                <div class="form-group">
                    <label>Product Name</label>
                    <input type="text" id="pName" placeholder="e.g. Black Hoodie" />
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <select id="pCat">
                        <option>Hoodie</option>
                        <option>T-Shirt</option>
                        <option>Jacket</option>
                        <option>Bottoms</option>
                        <option>Cap</option>
                        <option>Dress</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Price (₹)</label>
                    <input type="number" id="pPrice" placeholder="999" />
                </div>
                <div class="form-group">
                    <label>Stock</label>
                    <input type="number" id="pStock" placeholder="10" />
                </div>
                <div class="form-group full" style="grid-column:1/-1;">
                    <label>Image URL</label>
                    <input type="text" id="pImg" placeholder="https://..." />
                </div>
            </div>
            <button class="save-btn" style="margin-top:16px;" onclick="addProduct()">Add Product</button>
        </div>
    </div>

    <style>
        .filters-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .filter-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .filter-group select {
            padding: 9px 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 13px;
            font-family: 'Poppins', sans-serif;
            outline: none;
            background: white;
            cursor: pointer;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 2000;
        }

        .modal-overlay.show {
            display: block;
        }

        .modal {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            border-radius: 14px;
            width: 90%;
            max-width: 540px;
            z-index: 2001;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }

        .modal.show {
            display: block;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            border-bottom: 1px solid #eee;
        }

        .modal-header h3 {
            font-size: 16px;
            font-weight: 600;
        }

        .modal-header button {
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            color: #666;
        }

        .modal-body {
            padding: 24px;
        }
    </style>

    <script src="/shared.js"></script>
    <script>
        function toggleModal(show) {
            document.getElementById('modal').classList.toggle('show', show);
            document.getElementById('modalOverlay').classList.toggle('show', show);
        }

        function deleteRow(btn) {
            if (confirm('Delete this product?')) btn.closest('tr').remove();
        }

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const cat = document.getElementById('catFilter').value.toLowerCase();
            const status = document.getElementById('statusFilter').value.toLowerCase();
            document.querySelectorAll('#tableBody tr').forEach(row => {
                const name = row.cells[1].textContent.toLowerCase();
                const rowCat = (row.dataset.cat || '').toLowerCase();
                const rowStatus = (row.dataset.status || '').toLowerCase();
                const matchSearch = !search || name.includes(search);
                const matchCat = !cat || rowCat === cat;
                const matchStatus = !status || rowStatus === status.charAt(0).toUpperCase() + status.slice(1);
                row.style.display = (matchSearch && matchCat && matchStatus) ? '' : 'none';
            });
        }

        function addProduct() {
            const name = document.getElementById('pName').value.trim();
            const cat = document.getElementById('pCat').value;
            const price = document.getElementById('pPrice').value;
            const stock = document.getElementById('pStock').value;
            const img = document.getElementById('pImg').value.trim();
            if (!name || !price) return alert('Please fill required fields.');
            const tbody = document.getElementById('tableBody');
            const statusLabel = parseInt(stock) > 10 ? 'Active' : (parseInt(stock) > 0 ? 'Low' : 'Inactive');
            const statusClass = statusLabel.toLowerCase();
            const tr = document.createElement('tr');
            tr.dataset.cat = cat;
            tr.dataset.status = statusLabel;
            tr.innerHTML = `
        <td><img src="${img || 'https://via.placeholder.com/55'}" class="product-img" /></td>
        <td>${name}</td><td>${cat}</td><td>₹${price}</td><td>${stock}</td>
        <td><span class="status ${statusClass}">${statusLabel}</span></td>
        <td><button class="action-btn edit">Edit</button><button class="action-btn delete" onclick="deleteRow(this)">Delete</button></td>
      `;
            tbody.prepend(tr);
            toggleModal(false);
        }
    </script>
</body>

</html>