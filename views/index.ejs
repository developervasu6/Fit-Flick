<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIT-FLICK</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        nav {
            position: relative;
        }

        /* Search container */
        /* Base positioning */
        #search-bar {
            position: absolute;
            right: 10px;
            top: 60px;
            display: none;
            z-index: 1000;
        }

        /* Input default (collapsed) */
        #search-bar input {
            width: 0;
            opacity: 0;
            padding: 10px 15px;
            border-radius: 25px;
            border: 1px solid #ccc;
            outline: none;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        /* Expanded */
        #search-bar.active input {
            width: 260px;
            opacity: 1;
        }

        /* 🔻 Tablet */
        @media (max-width: 768px) {
            #search-bar {
                right: 10px;
                top: 55px;
            }

            #search-bar.active input {
                width: 180px;
            }
        }

        /* 🔻 Mobile */
        @media (max-width: 480px) {
            #search-bar {
                right: 0;
                left: 0;
                top: 60px;
                padding: 0 10px;
            }

            #search-bar input {
                width: 100% !important;
                opacity: 1 !important;
            }

            #search-bar.active input {
                width: 100%;
            }
        }
    </style>
</head>

<body>
