<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FIT-FLICK | Orders</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/shared.css" />
</head>

<body>
  <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <h2><a href="/">FIT-FLICK</a></h2>
      <button class="close-btn" onclick="closeSidebar()">
        <i class="fa fa-times"></i>
      </button>
    </div>
    <ul>
      <li>
        <a href="/admin"><i class="fa fa-home"></i> Dashboard</a>
      </li>
    
      <li>
        <a href="/admin/products"><i class="fa fa-tshirt"></i> Products</a>
      </li>
      <li>
        <a href="/admin/orders"><i class="fa fa-box"></i> Orders</a>
      </li>
      <li>
        <a href="/admin/customers"><i class="fa fa-users"></i> Customers</a>
      </li>
    </ul>
  </div>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="openSidebar()">
          <i class="fa fa-bars"></i>
        </button>
        <input type="text" placeholder="Search orders..." id="searchInput" oninput="filterOrders()" />
      </div>
      <a href="/profile" class="profile-link">
        <div class="profile-icon"><i class="fa fa-user"></i></div>
        <span class="profile-name">Admin</span>
      </a>
    </div>

    <div class="page-title">
      <h1>Orders</h1>
      <p>Track and manage customer orders</p>
    </div>

    <!-- Summary Cards -->
    <div class="cards">
      <div class="card">
        <div class="card-icon" style="background: rgba(17, 17, 17, 0.08); color: #111">
          <i class="fa fa-box"></i>
        </div>
        <div>
          <h3>
            <%= totalOrders %>
          </h3>
          <p>Total Orders</p>
        </div>
      </div>
      <div class="card">
        <div class="card-icon" style="background: rgba(255, 193, 7, 0.15); color: #d39e00">
          <i class="fa fa-clock"></i>
        </div>
        <div>
          <h3>
            <%= pendingOrders %>
          </h3>
          <p>Pending</p>
        </div>
      </div>
      <div class="card">
        <div class="card-icon" style="background: rgba(13, 110, 253, 0.1); color: #0d6efd">
          <i class="fa fa-truck"></i>
        </div>
        <div>
          <h3>
            <%= shippedOrders %>
          </h3>
          <p>Shipped</p>
        </div>
      </div>
      <div class="card">
        <div class="card-icon" style="background: rgba(40, 167, 69, 0.12); color: #28a745">
          <i class="fa fa-circle-check"></i>
        </div>
        <div>
          <h3>
            <%= deliveredOrders %>
          </h3>
          <p>Delivered</p>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="filters-bar">
      <div class="filter-group">
        <select id="statusFilter" onchange="filterOrders()">
          <option value="">All Status</option>
          <option>Pending</option>
          <option>Shipped</option>
          <option>Delivered</option>
          <option>Cancelled</option>
        </select>
        <select id="dateFilter" onchange="filterOrders()">
          <option value="">All Time</option>
          <option>Today</option>
          <option>This Week</option>
          <option>This Month</option>
        </select>
      </div>
      <button class="save-btn" style="margin-top: 0; padding: 10px 20px; font-size: 13px">
        <i class="fa fa-download"></i> Export
      </button>
    </div>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Product</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="ordersBody">
          <% orders.forEach(order=> {
            const customer = order.userId;
            const firstProduct = order.products[0];
            const productSummary = firstProduct
            ? `${firstProduct.name} × ${firstProduct.quantity}`
            : 'N/A';
            const avatarLetter = customer?.name?.charAt(0).toUpperCase() || '?';
            const date = new Date(order.createdAt).toLocaleDateString('en-IN', {
            day: '2-digit', month: 'short', year: 'numeric'
            });

            // Map your DB status to display labels
            const statusMap = {
            placed: 'Pending',
            shipped: 'Shipped',
            delivered: 'Delivered',
            cancelled: 'Cancelled'
            };
            const statusLabel = statusMap[order.status] || order.status;
            const statusClass = order.status === 'placed' ? 'pending' : order.status;
            %>
            <tr data-status="<%= statusLabel %>">
              <td><strong>#<%= order._id.toString().slice(-6).toUpperCase() %></strong></td>
              <td>
                <div class="cust-cell">
                  <div class="cust-avatar" style="background:#111;">
                    <%= avatarLetter %>
                  </div>
                  <div>
                    <div class="cust-name">
                      <%= customer?.name || 'Deleted User' %>
                    </div>
                    <div class="cust-email">
                      <%= customer?.email || '' %>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <%= productSummary %>
              </td>
              <td>₹<%= order.totalBill.toLocaleString('en-IN') %>
              </td>
              <td>
                <%= date %>
              </td>
              <td><span class="status <%= statusClass %>">
                  <%= statusLabel %>
                </span></td>
              <td>
                <button class="action-btn view" onclick="viewOrder('<%= order._id %>')">View</button>
                <% if (order.status !=='cancelled' && order.status !=='delivered' ) { %>
                  <button class="action-btn edit" onclick="updateStatus('<%= order._id %>', this)">Update</button>
                  <% } %>
              </td>
            </tr>
            <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <style>
    .filters-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .filter-group {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .filter-group select {
      padding: 9px 14px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 13px;
      font-family: "Poppins", sans-serif;
      outline: none;
      background: white;
      cursor: pointer;
    }

    .cust-cell {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .cust-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      flex-shrink: 0;
    }

    .cust-name {
      font-size: 13px;
      font-weight: 500;
      color: #111;
    }

    .cust-email {
      font-size: 11px;
      color: #6c757d;
    }
  </style>

  <script src="/shared.js"></script>
  <script>
    async function updateStatus(orderId, btn) {
      const next = {
        'placed': 'shipped',
        'shipped': 'delivered'
      };

      const row = btn.closest('tr');
      const currentLabel = row.dataset.status;
      const currentDB = currentLabel === 'Pending' ? 'placed' : currentLabel.toLowerCase();
      const nextStatus = next[currentDB];

      if (!nextStatus) return alert('Cannot update further');

      const res = await fetch(`/admin/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: nextStatus })
      });

      if (res.ok) location.reload();
      else alert('Failed to update status');
    }
  </script>
</body>

</html>